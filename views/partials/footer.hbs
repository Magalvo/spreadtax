<style>
  /* ── Footer ── */
  .st-footer {
    background: var(--surface);
    border-top: 1px solid var(--border-mid);
    padding: 5rem 4rem 2rem;
    font-family: var(--font-body);
    transition:
      background 0.3s ease,
      border-color 0.3s ease;
  }

  [data-theme="dark"] .st-footer {
    background: #0a0d13;
  }

  .st-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border-mid);
    margin-bottom: 2.5rem;
  }

  /* Brand column */
  .st-footer__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 1rem;
    height: 32px;
  }
  .st-footer__brand img {
    height: 100%;
    width: auto;
    object-fit: contain;
    opacity: 0.8;
    transition: opacity 0.18s;
  }
  .st-footer__brand:hover img {
    opacity: 1;
  }

  .st-footer__tagline {
    font-size: 0.875rem;
    color: var(--ink-muted);
    line-height: 1.7;
    max-width: 36ch;
  }

  /* Column headings */
  .st-footer__col-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1.25rem;
    font-weight: 500;
  }

  /* Link lists */
  .st-footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .st-footer__list a {
    font-size: 0.8125rem;
    color: var(--ink-muted);
    text-decoration: none;
    transition:
      color 0.18s,
      padding-left 0.18s;
    padding-left: 0;
  }
  .st-footer__list a:hover {
    color: var(--accent-bright);
    padding-left: 0.25rem;
  }

  /* Address / contact */
  .st-footer__address {
    font-style: normal;
    font-size: 0.8125rem;
    color: var(--ink-muted);
    line-height: 1.85;
  }
  .st-footer__address a {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.18s;
    border-bottom: 1px solid var(--border-mid);
  }
  .st-footer__address a:hover {
    color: var(--accent-bright);
    border-bottom-color: var(--accent-bright);
  }

  /* Bottom bar */
  .st-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .st-footer__copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
  }

  .st-footer__bottom-links {
    display: flex;
    gap: 1.75rem;
    list-style: none;
  }
  .st-footer__bottom-links a {
    font-size: 0.7rem;
    color: var(--ink-faint);
    text-decoration: none;
    transition: color 0.18s;
    letter-spacing: 0.02em;
  }
  .st-footer__bottom-links a:hover {
    color: var(--ink-muted);
  }

  @media (max-width: 900px) {
    .st-footer {
      padding: 3.5rem 1.5rem 2rem;
    }
    .st-footer__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .st-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<footer class="st-footer" role="contentinfo">
  <div class="st-footer__grid">

    {{! Brand + tagline }}
    <div>
      <a class="st-footer__brand" href="/" title="SpreadTax Home">
        <img src="/images/HandlebarsNewSpread.png" alt="SpreadTax Logo" />
      </a>
      <p class="st-footer__tagline">
        Accounting made easy — for accountants and their clients. Streamline
        collaboration, automate data entry, and stay in control.
      </p>
    </div>

    {{! Quick links }}
    <div>
      <p class="st-footer__col-title">Links</p>
      <ul class="st-footer__list">
        <li><a href="/">Home</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#plans">Pricing</a></li>
        <li><a href="/signup">Register</a></li>
        <li><a href="/login">Login</a></li>
      </ul>
    </div>

    {{! Contact }}
    <div>
      <p class="st-footer__col-title">Contact</p>
      <address class="st-footer__address">
        Lisbon, Portugal<br />
        <a href="tel:+351919990001">(351) 919 990 001</a><br />
        <a href="mailto:info@example.com">spreadt4x@gmail.com</a>
      </address>
    </div>

  </div>

  <div class="st-footer__bottom">
    <span class="st-footer__copy">&copy; 2026 Spread Tax. All rights reserved.</span>
    <ul class="st-footer__bottom-links">
      <li><a href="#">Privacy</a></li>
      <li><a href="#">Terms</a></li>
    </ul>
  </div>
</footer>