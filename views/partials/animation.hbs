<style>
  /* ── Intro animation overlay ── */
  .st-intro {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: #1a4d3b;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1.5rem;
    /* fade out after JS hides it */
    transition:
      opacity 0.5s ease,
      visibility 0.5s ease;
  }
  .st-intro.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Wordmark */
  .st-intro__logo {
    font-family: "DM Serif Display", serif;
    font-size: 2.25rem;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: -0.02em;
    animation: stIntroPulse 1.8s ease-in-out infinite;
  }
  .st-intro__logo em {
    font-style: italic;
    color: #22c77a;
  }

  /* Animated progress bar */
  .st-intro__bar-track {
    width: 160px;
    height: 2px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 1px;
    overflow: hidden;
  }
  .st-intro__bar-fill {
    height: 100%;
    width: 0;
    background: #22c77a;
    border-radius: 1px;
    animation: stIntroBar 1.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* Three-dot pulse */
  .st-intro__dots {
    display: flex;
    gap: 6px;
  }
  .st-intro__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    animation: stIntroDot 1.2s ease-in-out infinite both;
  }
  .st-intro__dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  .st-intro__dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes stIntroPulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  @keyframes stIntroBar {
    0% {
      width: 0;
    }
    60% {
      width: 80%;
    }
    100% {
      width: 100%;
    }
  }

  @keyframes stIntroDot {
    0%,
    80%,
    100% {
      transform: scale(1);
      opacity: 0.35;
    }
    40% {
      transform: scale(1.5);
      opacity: 1;
    }
  }
</style>

<div
  id="animation"
  class="st-intro"
  role="status"
  aria-label="Loading SpreadTax"
>
  <div class="st-intro__logo">Spread<em>tax</em></div>
  <div class="st-intro__bar-track">
    <div class="st-intro__bar-fill"></div>
  </div>
  <div class="st-intro__dots" aria-hidden="true">
    <div class="st-intro__dot"></div>
    <div class="st-intro__dot"></div>
    <div class="st-intro__dot"></div>
  </div>
</div>

<script>
  (function () { /* Match original 2 000 ms timing; swap animation out, reveal
  form */ setTimeout(function () { var animation =
  document.getElementById('animation'); var form =
  document.getElementById('form'); if (animation)
  animation.classList.add('is-hidden'); /* After the CSS fade-out finishes (500
  ms), remove from layout */ setTimeout(function () { if (animation)
  animation.style.display = 'none'; }, 500); if (form) form.style.display =
  'block'; }, 2000); })();
</script>