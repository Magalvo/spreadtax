{{! ─── SCRIPTS ───────────────────────────────────────────── }}
<script>
  (function () { /* ── Plan tab active-state ── */ const planLabels = { isFree:
  'Create free account', isPremium: 'Start Premium plan', isUnlimited: 'Start
  Unlimited plan' }; const tabs = document.querySelectorAll('.st-reg-tabs
  label'); const radios = document.querySelectorAll('.st-reg-tabs
  input[type="radio"]'); const submitBtn =
  document.getElementById('st-submit-btn'); function syncTabs () {
  radios.forEach(function (radio, i) { tabs[i].classList.toggle('is-active',
  radio.checked); if (radio.checked && submitBtn) { submitBtn.textContent =
  planLabels[radio.value] || 'Register today'; } }); } radios.forEach(function
  (radio) { radio.addEventListener('change', syncTabs); }); /* Pre-select from
  URL param (e.g. /auth/signup?value=isPremium link) */ const urlParams = new
  URLSearchParams(window.location.search); const urlValue =
  urlParams.get('value'); if (urlValue) { radios.forEach(function (radio) { if
  (radio.value === urlValue) radio.checked = true; }); } syncTabs(); /* ── Form
  validation ── */ var form = document.getElementById('st-reg-form'); if (form)
  { form.addEventListener('submit', function (e) { if (!form.checkValidity()) {
  e.preventDefault(); form.querySelectorAll('.st-field').forEach(function (f) {
  f.classList.add('was-validated'); }); } }); } /* ── Scroll-reveal on plan
  cards and stat blocks ── */ if ('IntersectionObserver' in window) { var
  revealEls = document.querySelectorAll('.st-plan, .st-stat,
  .st-features__item'); revealEls.forEach(function (el) { el.style.opacity =
  '0'; el.style.transform = 'translateY(18px)'; el.style.transition = 'opacity
  0.5s ease, transform 0.5s ease'; }); var io = new
  IntersectionObserver(function (entries) { entries.forEach(function (entry) {
  if (entry.isIntersecting) { entry.target.style.opacity = '1';
  entry.target.style.transform = 'translateY(0)'; io.unobserve(entry.target); }
  }); }, { threshold: 0.12 }); revealEls.forEach(function (el) { io.observe(el);
  }); } })();
</script>